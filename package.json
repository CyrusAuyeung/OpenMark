{
  "name": "openmark-editor",
  "version": "0.1.0",
  "description": "A local-first Markdown editor MVP built with React, CodeMirror, and markdown-it.",
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "react",
    "local-first"
  ],
  "homepage": "https://github.com/CyrusAuyeung/OpenMark#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyrusAuyeung/OpenMark.git"
  },
  "bugs": {
    "url": "https://github.com/CyrusAuyeung/OpenMark/issues"
  },
  "author": "OpenMark contributors",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently -k \"npm run dev -- --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "desktop:start": "npm run build && electron .",
    "package": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "dev.openmark.editor",
    "productName": "OpenMark",
    "copyright": "Copyright © 2026 OpenMark contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenMark"
    }
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.10",
    "dompurify": "^3.4.8",
    "lucide-react": "^1.17.0",
    "markdown-it": "^14.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
