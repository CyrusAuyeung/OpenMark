{
  "name": "openmark-editor",
  "version": "0.28.0",
  "description": "A local-first Markdown editor MVP built with React, CodeMirror, and markdown-it.",
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "react",
    "local-first"
  ],
  "homepage": "https://github.com/CyrusAuyeung/OpenMark#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyrusAuyeung/OpenMark.git"
  },
  "bugs": {
    "url": "https://github.com/CyrusAuyeung/OpenMark/issues"
  },
  "author": "OpenMark contributors",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently -k \"npm run dev -- --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "desktop:start": "npm run build && electron .",
    "package": "npm run build && electron-builder --dir --config electron-builder.config.cjs",
    "dist:win": "npm run build && electron-builder --win --config electron-builder.config.cjs",
    "dist:mac": "npm run build && electron-builder --mac --config electron-builder.config.cjs",
    "dist:linux": "npm run build && electron-builder --linux --config electron-builder.config.cjs",
    "build": "tsc -b && vite build",
    "build:budget": "node scripts/check-build-budget.mjs",
    "lint": "eslint .",
    "test": "vitest run --environment jsdom",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "release:check": "node scripts/check-release.mjs",
    "release:verify": "node scripts/verify-github-release.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/search": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.10",
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.17.0",
    "markdown-it": "^14.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
